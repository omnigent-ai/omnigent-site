{
  "name": "omnigent-site",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "scripts": {
    "og:manifest": "node scripts/gen-og-manifest.mjs",
    "dev": "node scripts/gen-og-manifest.mjs && next dev",
    "build": "node scripts/gen-og-manifest.mjs && next build && node scripts/build-search-index.mjs",
    "start": "next start",
    "lint": "next lint",
    "lint:links": "node scripts/check-links.mjs",
    "fmt": "prettier --write .",
    "fmt:check": "prettier --check .",
    "strip-lock-proxy": "bun run scripts/strip-bun-lock-proxy.ts",
    "strip-lock-proxy:check": "bun run scripts/strip-bun-lock-proxy.ts --check",
    "setup-hooks": "git config core.hooksPath .githooks",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@next/mdx": "14.2.35",
    "@scalar/api-reference-react": "^0.9.46",
    "@vercel/analytics": "^2.0.1",
    "next": "^14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remark-gfm": "^4.0.1",
    "resend": "^6.16.0"
  },
  "devDependencies": {
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.35",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.4"
  }
}
